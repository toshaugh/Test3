# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
# Add a PostgreSQL plugin in Railway; it will auto-populate DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# For Prisma migrations (direct connection, bypasses PgBouncer pooling)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Your deployed Railway URL, e.g. https://my-app.up.railway.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Apple Sign In ────────────────────────────────────────────────────────────
# https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_ID=""        # Services ID (e.g. com.example.app.signin)
APPLE_SECRET=""    # Generated JWT: see https://authjs.dev/reference/core/providers/apple

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# https://github.com/settings/applications/new
GITHUB_ID=""
GITHUB_SECRET=""

# ─── Email (magic links via Nodemailer) ───────────────────────────────────────
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@example.com"
